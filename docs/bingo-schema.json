{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"title": "Schema used for Bingo goals",
	"$id": "https://github.com/WarperSan/BingoAPI/schema.json",
	"$defs": {
		"goal": {
			"type": "object",
			"properties": {
				"name": {
					"type": "string"
				},
				"condition": {
					"$ref": "#/$defs/condition"
				}
			},
			"required": [
				"name",
				"condition"
			]
		},
		"condition": {
			"type": "object",
			"required": [
				"action"
			],
			"properties": {
				"action": {
					"type": "string"
				},
				"params": {
					"type": "object"
				}
			}
		},
		"and-condition": {
			"type": "object",
			"properties": {
				"action": {
					"type": "string",
					"const": "AND"
				},
				"params": {
					"type": "object",
					"properties": {
						"conditions": {
							"type": "array",
							"items": {
								"$ref": "#/$defs/condition"
							},
							"minItems": 1
						}
					},
					"required": [
						"conditions"
					]
				}
			},
			"required": [
				"action",
				"params"
			]
		},
		"or-condition": {
			"type": "object",
			"properties": {
				"action": {
					"type": "string",
					"const": "OR"
				},
				"params": {
					"type": "object",
					"properties": {
						"conditions": {
							"type": "array",
							"items": {
								"$ref": "#/$defs/condition"
							},
							"minItems": 1
						}
					},
					"required": [
						"conditions"
					]
				}
			},
			"required": [
				"action",
				"params"
			]
		},
		"some-condition": {
			"type": "object",
			"properties": {
				"action": {
					"type": "string",
					"const": "SOME"
				},
				"params": {
					"type": "object",
					"properties": {
						"conditions": {
							"type": "array",
							"items": {
								"$ref": "#/$defs/condition"
							},
							"minItems": 1
						},
						"amount": {
							"type": "number",
							"default": 1,
							"minimum": 1
						}
					},
					"required": [
						"conditions"
					]
				}
			},
			"required": [
				"action",
				"params"
			]
		},
		"not-condition": {
			"type": "object",
			"properties": {
				"action": {
					"type": "string",
					"const": "NOT"
				},
				"params": {
					"type": "object",
					"properties": {
						"condition": {
							"$ref": "#/$defs/condition"
						}
					},
					"required": [
						"condition"
					]
				}
			},
			"required": [
				"action",
				"params"
			]
		}
	},
	"type": "array",
	"items": {
		"$ref": "#/$defs/goal"
	}
}
