{
d"$schema": "https://alirezanet.github.io/Husky.Net/schema.json",
	"tasks": [
		{
			"name": "Run CSharpier",
			"group": "pre-commit",
			"command": "dotnet",
			"args": [
				"csharpier",
				"format",
				"${staged}"
			],
			"include": [
				"**/*.cs",
				"**/*.csproj",
				"**/*.props",
				"**/*.targets"
			]
		}
	]
}
